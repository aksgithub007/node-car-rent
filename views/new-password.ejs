<%- include('includes/Head') %>

  <%- include('includes/Navigation') %>

  <!-- ─── Auth Page Wrapper ────────────────────────────────────── -->
  <main class="auth-page">

    <!-- Background decorative glow -->
    <div class="auth-glow auth-glow--left"></div>
    <div class="auth-glow auth-glow--right"></div>

    <div class="auth-container">

      <!-- ─── Left Panel: Branding ─────────────────────────────── -->
      <div class="auth-panel auth-panel--brand">
        <div class="brand-panel-inner">

          <a href="/" class="auth-logo">
            <div class="logo-mark">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 11l1.5-4.5A2 2 0 016.4 5h11.2a2 2 0 011.9 1.5L21 11M3 11v5a1 1 0 001 1h1a2 2 0 004 0h6a2 2 0 004 0h1a1 1 0 001-1v-5M3 11h18M7 17a1 1 0 110-2 1 1 0 010 2zm10 0a1 1 0 110-2 1 1 0 010 2z"/>
              </svg>
            </div>
            <span class="logo-text">Drive<span>Elite</span></span>
          </a>

          <div class="brand-copy">
            <h2 class="brand-heading">Almost there,<br/>set your key.</h2>
            <p class="brand-sub">Choose a strong new password to secure your account and get back on the road.</p>
          </div>

          <ul class="brand-features">
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Minimum 8 characters</span>
            </li>
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Encrypted and stored securely</span>
            </li>
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Previous passwords not reused</span>
            </li>
          </ul>

          <!-- Decorative car silhouette line -->
          <div class="brand-car-art" aria-hidden="true">
            <svg viewBox="0 0 320 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 62 L52 34 L90 28 L160 24 L220 28 L262 34 L290 50 L300 62 L300 72 L20 72 Z"
                stroke="rgba(232,200,74,0.18)" stroke-width="1.5" fill="rgba(232,200,74,0.03)"/>
              <circle cx="75" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="245" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="75" cy="72" r="4" fill="rgba(232,200,74,0.2)"/>
              <circle cx="245" cy="72" r="4" fill="rgba(232,200,74,0.2)"/>
            </svg>
          </div>

        </div>
      </div><!-- /.auth-panel--brand -->

      <!-- ─── Right Panel: Form ─────────────────────────────────── -->
      <div class="auth-panel auth-panel--form">
        <div class="form-panel-inner">

          <div class="auth-form-header">
            <span class="auth-tag">Security Update</span>
            <h1 class="auth-title">New Password</h1>
            <p class="auth-subtitle">Enter and confirm your new password below</p>
          </div>

          <% if (locals.error) { %>
            <div class="auth-alert auth-alert--error">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
              </svg>
              <span><%= error %></span>
            </div>
          <% } %>

   

          <!-- Pass the token from the URL into the form -->
          <form action="/admin/update-password" method="POST" class="auth-form" novalidate id="update-pwd-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <!-- New Password -->
            <div class="field-group">
              <label class="field-label" for="newPassword">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                </svg>
                New Password
              </label>
              <div class="field-wrap field-wrap--password">
                <input
                  type="password"
                  id="newPassword"
                  name="newPassword"
                  class="field-input"
                  placeholder="Enter new password"
                  autocomplete="new-password"
                  required
                  minlength="8"
                
                  autofocus
                />
                <button type="button" class="pwd-toggle" aria-label="Toggle password visibility" onclick="togglePassword('newPassword', this)">
                  <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
                  </svg>
                </button>
              </div>
              <!-- Password strength bar -->
              <div class="pwd-strength">
                <div class="pwd-strength-bar">
                  <div class="pwd-strength-fill" id="strength-fill"></div>
                </div>
                <span class="pwd-strength-label" id="strength-label"></span>
              </div>
            </div>

            <!-- Confirm Password -->
            <div class="field-group">
              <label class="field-label" for="confirmPassword">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Confirm Password
              </label>
              <div class="field-wrap field-wrap--password">
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  class="field-input"
                  placeholder="Re-enter new password"
                  autocomplete="new-password"
                  required
                />
                <button type="button" class="pwd-toggle" aria-label="Toggle confirm password visibility" onclick="togglePassword('confirmPassword', this)">
                  <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
                  </svg>
                </button>
              </div>
              <!-- Match indicator -->
              <p class="pwd-match-msg" id="match-msg"></p>
            </div>

            <!-- Submit -->
             <input type="hidden" name="userId" value="<%= userId %>">
             <input type="hidden" name="token" value="<%= token %>">
            <button type="submit" class="auth-btn auth-btn--primary" id="submit-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
              </svg>
              Update Password
            </button>

          </form>

          <div class="auth-divider"><span>Remembered your password?</span></div>

          <a href="/auth/login" class="auth-btn auth-btn--ghost">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
            </svg>
            Back to Sign In
          </a>

        </div>
      </div><!-- /.auth-panel--form -->

    </div><!-- /.auth-container -->
  </main>
<%- include('includes/Toast') %>
  <%- include('includes/Footer') %>


  <script>
    // ─── Toggle password visibility ──────────────────────────
    // Auto-focus first visible field on page load
    document.addEventListener('DOMContentLoaded', function() {
      const first = document.querySelector('.field-input:not([type="hidden"]), .field-select');
      if (first) { first.focus(); }
    });

    function togglePassword(inputId, btn) {
      const input = document.getElementById(inputId);
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      btn.querySelector('.eye-show').style.display = isText ? '' : 'none';
      btn.querySelector('.eye-hide').style.display = isText ? 'none' : '';
    }

    // ─── Password strength meter ──────────────────────────────
    const newPwd   = document.getElementById('newPassword');
    const confirmPwd = document.getElementById('confirmPassword');
    const fill     = document.getElementById('strength-fill');
    const label    = document.getElementById('strength-label');
    const matchMsg = document.getElementById('match-msg');
    const submitBtn = document.getElementById('submit-btn');

    function getStrength(pwd) {
      let score = 0;
      if (pwd.length >= 8)  score++;
      if (pwd.length >= 12) score++;
      if (/[A-Z]/.test(pwd)) score++;
      if (/[0-9]/.test(pwd)) score++;
      if (/[^A-Za-z0-9]/.test(pwd)) score++;
      return score;
    }

    const levels = [
      { pct: '0%',   color: 'transparent',          text: '',        textColor: 'var(--text-muted)' },
      { pct: '25%',  color: '#ff4b4b',               text: 'Weak',    textColor: '#ff7a7a' },
      { pct: '50%',  color: '#f97316',               text: 'Fair',    textColor: '#fb923c' },
      { pct: '75%',  color: '#e8c84a',               text: 'Good',    textColor: 'var(--accent)' },
      { pct: '88%',  color: '#4ade80',               text: 'Strong',  textColor: '#4ade80' },
      { pct: '100%', color: '#4ade80',               text: 'Strong',  textColor: '#4ade80' },
    ];

    newPwd.addEventListener('input', () => {
      const score = getStrength(newPwd.value);
      const lv = levels[score] || levels[0];
      fill.style.width = lv.pct;
      fill.style.background = lv.color;
      label.textContent = lv.text;
      label.style.color = lv.textColor;
      checkMatch();
    });

    // ─── Confirm password match check ────────────────────────
    function checkMatch() {
      if (!confirmPwd.value) {
        matchMsg.textContent = '';
        confirmPwd.classList.remove('input--error', 'input--success');
        submitBtn.disabled = true;
        return;
      }
      const match = newPwd.value === confirmPwd.value;
      confirmPwd.classList.toggle('input--error', !match);
      confirmPwd.classList.toggle('input--success', match);
      matchMsg.textContent = match ? '✓ Passwords match' : '✗ Passwords do not match';
      matchMsg.style.color = match ? '#4ade80' : '#ff7a7a';
      submitBtn.disabled = !match || newPwd.value.length < 8;
    }

    confirmPwd.addEventListener('input', checkMatch);

    // Disable submit on page load until valid
    submitBtn.disabled = true;
  </script>
