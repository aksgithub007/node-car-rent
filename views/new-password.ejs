<%- include('includes/Head') %>

  <%- include('includes/Navigation') %>

  <!-- ─── Auth Page Wrapper ────────────────────────────────────── -->
  <main class="auth-page">

    <!-- Background decorative glow -->
    <div class="auth-glow auth-glow--left"></div>
    <div class="auth-glow auth-glow--right"></div>

    <div class="auth-container">

      <!-- ─── Left Panel: Branding ─────────────────────────────── -->
      <div class="auth-panel auth-panel--brand">
        <div class="brand-panel-inner">

          <a href="/" class="auth-logo">
            <div class="logo-mark">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 11l1.5-4.5A2 2 0 016.4 5h11.2a2 2 0 011.9 1.5L21 11M3 11v5a1 1 0 001 1h1a2 2 0 004 0h6a2 2 0 004 0h1a1 1 0 001-1v-5M3 11h18M7 17a1 1 0 110-2 1 1 0 010 2zm10 0a1 1 0 110-2 1 1 0 010 2z"/>
              </svg>
            </div>
            <span class="logo-text">Drive<span>Elite</span></span>
          </a>

          <div class="brand-copy">
            <h2 class="brand-heading">Almost there,<br/>set your key.</h2>
            <p class="brand-sub">Choose a strong new password to secure your account and get back on the road.</p>
          </div>

          <ul class="brand-features">
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Minimum 8 characters</span>
            </li>
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Encrypted and stored securely</span>
            </li>
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Previous passwords not reused</span>
            </li>
          </ul>

          <!-- Decorative car silhouette line -->
          <div class="brand-car-art" aria-hidden="true">
            <svg viewBox="0 0 320 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 62 L52 34 L90 28 L160 24 L220 28 L262 34 L290 50 L300 62 L300 72 L20 72 Z"
                stroke="rgba(232,200,74,0.18)" stroke-width="1.5" fill="rgba(232,200,74,0.03)"/>
              <circle cx="75" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="245" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="75" cy="72" r="4" fill="rgba(232,200,74,0.2)"/>
              <circle cx="245" cy="72" r="4" fill="rgba(232,200,74,0.2)"/>
            </svg>
          </div>

        </div>
      </div><!-- /.auth-panel--brand -->

      <!-- ─── Right Panel: Form ─────────────────────────────────── -->
      <div class="auth-panel auth-panel--form">
        <div class="form-panel-inner">

          <div class="auth-form-header">
            <span class="auth-tag">Security Update</span>
            <h1 class="auth-title">New Password</h1>
            <p class="auth-subtitle">Enter and confirm your new password below</p>
          </div>

          <% if (locals.error) { %>
            <div class="auth-alert auth-alert--error">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
              </svg>
              <span><%= error %></span>
            </div>
          <% } %>

   

          <!-- Pass the token from the URL into the form -->
          <form action="/admin/update-password" method="POST" class="auth-form" novalidate id="update-pwd-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <!-- New Password -->
            <div class="field-group">
              <label class="field-label" for="newPassword">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                </svg>
                New Password
              </label>
              <div class="field-wrap field-wrap--password">
                <input
                  type="password"
                  id="newPassword"
                  name="newPassword"
                  class="field-input"
                  placeholder="Enter new password"
                  autocomplete="new-password"
                  required
                  minlength="8"
                />
                <button type="button" class="pwd-toggle" aria-label="Toggle password visibility" onclick="togglePassword('newPassword', this)">
                  <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
                  </svg>
                </button>
              </div>
              <!-- Password strength bar -->
              <div class="pwd-strength">
                <div class="pwd-strength-bar">
                  <div class="pwd-strength-fill" id="strength-fill"></div>
                </div>
                <span class="pwd-strength-label" id="strength-label"></span>
              </div>
            </div>

            <!-- Confirm Password -->
            <div class="field-group">
              <label class="field-label" for="confirmPassword">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Confirm Password
              </label>
              <div class="field-wrap field-wrap--password">
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  class="field-input"
                  placeholder="Re-enter new password"
                  autocomplete="new-password"
                  required
                />
                <button type="button" class="pwd-toggle" aria-label="Toggle confirm password visibility" onclick="togglePassword('confirmPassword', this)">
                  <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
                  </svg>
                </button>
              </div>
              <!-- Match indicator -->
              <p class="pwd-match-msg" id="match-msg"></p>
            </div>

            <!-- Submit -->
             <input type="hidden" name="userId" value="<%= userId %>">
             <input type="hidden" name="token" value="<%= token %>">
            <button type="submit" class="auth-btn auth-btn--primary" id="submit-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
              </svg>
              Update Password
            </button>

          </form>

          <div class="auth-divider"><span>Remembered your password?</span></div>

          <a href="/auth/login" class="auth-btn auth-btn--ghost">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
            </svg>
            Back to Sign In
          </a>

        </div>
      </div><!-- /.auth-panel--form -->

    </div><!-- /.auth-container -->
  </main>
<%- include('includes/Toast') %>
  <%- include('includes/Footer') %>

  <style>
    /* ─── Auth Page Styles ────────────────────────────────────── */
    .auth-page {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 100px 24px 60px;
      z-index: 1;
      overflow: hidden;
    }

    .auth-glow {
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
      filter: blur(80px);
    }

    .auth-glow--left {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(232,200,74,0.07) 0%, transparent 70%);
      top: 10%; left: -100px;
    }

    .auth-glow--right {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(100,80,200,0.06) 0%, transparent 70%);
      bottom: 10%; right: -80px;
    }

    /* ─── Container ─────────────────────────────────────────── */
    .auth-container {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 960px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.03);
      animation: authIn 0.6s cubic-bezier(0.4,0,0.2,1) both;
    }

    @keyframes authIn {
      from { opacity: 0; transform: translateY(32px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ─── Brand Panel ───────────────────────────────────────── */
    .auth-panel--brand {
      position: relative;
      background: linear-gradient(145deg, #0e0e18 0%, #111120 60%, #141428 100%);
      border-right: 1px solid var(--card-border);
      overflow: hidden;
    }

    .auth-panel--brand::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .auth-panel--brand::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 50% at 30% 20%, rgba(232,200,74,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 80%, rgba(100,80,200,0.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .brand-panel-inner {
      position: relative;
      z-index: 1;
      padding: 48px 40px;
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .auth-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .logo-mark {
      width: 36px; height: 36px;
      border-radius: 9px;
      background: var(--accent-dim);
      border: 1px solid rgba(232,200,74,0.3);
      display: grid;
      place-items: center;
    }

    .logo-mark svg {
      width: 18px; height: 18px;
      stroke: var(--accent);
      fill: none;
      stroke-width: 1.6;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .logo-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
      letter-spacing: 0.06em;
      color: var(--text-primary);
    }

    .logo-text span { color: var(--accent); }

    .brand-heading {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 42px;
      letter-spacing: 0.04em;
      color: var(--text-primary);
      line-height: 1.1;
    }

    .brand-sub {
      margin-top: 12px;
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.7;
    }

    .brand-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: auto;
    }

    .brand-features li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
      color: var(--text-label);
    }

    .feat-icon {
      width: 28px; height: 28px;
      border-radius: 7px;
      background: var(--accent-dim);
      border: 1px solid rgba(232,200,74,0.2);
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .feat-icon svg { width: 14px; height: 14px; stroke: var(--accent); }

    .brand-car-art { margin-top: 8px; opacity: 0.8; }
    .brand-car-art svg { width: 100%; }

    /* ─── Form Panel ────────────────────────────────────────── */
    .auth-panel--form { background: var(--card-bg); }

    .form-panel-inner {
      padding: 48px 40px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .auth-tag {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      background: var(--accent-dim);
      border: 1px solid rgba(232,200,74,0.25);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .auth-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 40px;
      letter-spacing: 0.04em;
      color: var(--text-primary);
      line-height: 1;
      margin-top: 8px;
    }

    .auth-subtitle {
      font-size: 14px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    /* ─── Alerts ────────────────────────────────────────────── */
    .auth-alert {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
    }

    .auth-alert--error {
      background: rgba(255,75,75,0.1);
      border: 1px solid rgba(255,75,75,0.3);
      color: #ff7a7a;
    }

    .auth-alert--success {
      background: rgba(74,222,128,0.08);
      border: 1px solid rgba(74,222,128,0.25);
      color: #4ade80;
    }

    .auth-alert svg { width: 16px; height: 16px; flex-shrink: 0; }

    /* ─── Form Fields ───────────────────────────────────────── */
    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .field-group { display: flex; flex-direction: column; gap: 8px; }

    .field-label {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-label);
    }

    .field-label svg { width: 13px; height: 13px; stroke: var(--text-muted); }

    .field-wrap { position: relative; }

    .field-input {
      width: 100%;
      padding: 13px 16px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--card-border);
      border-radius: 10px;
      color: var(--text-primary);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
    }

    .field-input::placeholder { color: var(--text-muted); }

    .field-input:focus {
      border-color: rgba(232,200,74,0.5);
      background: rgba(232,200,74,0.03);
      box-shadow: 0 0 0 3px rgba(232,200,74,0.08);
    }

    .field-input.input--error {
      border-color: rgba(255,75,75,0.5);
      box-shadow: 0 0 0 3px rgba(255,75,75,0.08);
    }

    .field-input.input--success {
      border-color: rgba(74,222,128,0.4);
      box-shadow: 0 0 0 3px rgba(74,222,128,0.07);
    }

    .field-wrap--password .field-input { padding-right: 48px; }

    .pwd-toggle {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      display: grid;
      place-items: center;
      color: var(--text-muted);
      transition: color var(--transition);
    }

    .pwd-toggle:hover { color: var(--text-primary); }
    .pwd-toggle svg { width: 16px; height: 16px; stroke: currentColor; }

    /* ─── Password Strength Bar ────────────────────────────── */
    .pwd-strength {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 2px;
    }

    .pwd-strength-bar {
      flex: 1;
      height: 3px;
      background: var(--card-border);
      border-radius: 100px;
      overflow: hidden;
    }

    .pwd-strength-fill {
      height: 100%;
      width: 0%;
      border-radius: 100px;
      transition: width 0.4s var(--transition), background 0.4s var(--transition);
    }

    .pwd-strength-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      min-width: 44px;
      text-align: right;
      color: var(--text-muted);
      transition: color 0.3s;
    }

    /* ─── Match Message ─────────────────────────────────────── */
    .pwd-match-msg {
      font-size: 12px;
      font-weight: 500;
      min-height: 16px;
      transition: color 0.3s;
    }

    /* ─── Buttons ───────────────────────────────────────────── */
    .auth-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 14px 20px;
      border-radius: var(--radius-btn);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.04em;
      cursor: pointer;
      text-decoration: none;
      transition: all var(--transition);
      border: none;
    }

    .auth-btn svg { width: 16px; height: 16px; flex-shrink: 0; }

    .auth-btn--primary {
      background: var(--accent);
      color: var(--bg);
      text-transform: uppercase;
      position: relative;
      overflow: hidden;
    }

    .auth-btn--primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0);
      transition: background var(--transition);
    }

    .auth-btn--primary:hover::before { background: rgba(255,255,255,0.12); }
    .auth-btn--primary:active { transform: scale(0.98); }

    .auth-btn--primary:disabled {
      opacity: 0.4;
      cursor: not-allowed;
      pointer-events: none;
    }

    .auth-btn--ghost {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--card-border);
      color: var(--text-label);
      font-size: 13px;
    }

    .auth-btn--ghost:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.12);
      color: var(--text-primary);
    }

    .auth-btn--ghost svg { stroke: currentColor; }

    /* ─── Divider ───────────────────────────────────────────── */
    .auth-divider { position: relative; text-align: center; }

    .auth-divider::before {
      content: '';
      position: absolute;
      top: 50%; left: 0; right: 0;
      height: 1px;
      background: var(--card-border);
    }

    .auth-divider span {
      position: relative;
      background: var(--card-bg);
      padding: 0 12px;
      font-size: 12px;
      color: var(--text-muted);
      letter-spacing: 0.04em;
    }

    /* ─── Responsive ────────────────────────────────────────── */
    @media (max-width: 768px) {
      .auth-container {
        grid-template-columns: 1fr;
        max-width: 480px;
      }
      .auth-panel--brand { display: none; }
      .form-panel-inner { padding: 40px 28px; }
    }

    @media (max-width: 480px) {
      .auth-page { padding: 90px 16px 40px; }
      .form-panel-inner { padding: 32px 20px; }
    }
  </style>

  <script>
    // ─── Toggle password visibility ──────────────────────────
    function togglePassword(inputId, btn) {
      const input = document.getElementById(inputId);
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      btn.querySelector('.eye-show').style.display = isText ? '' : 'none';
      btn.querySelector('.eye-hide').style.display = isText ? 'none' : '';
    }

    // ─── Password strength meter ──────────────────────────────
    const newPwd   = document.getElementById('newPassword');
    const confirmPwd = document.getElementById('confirmPassword');
    const fill     = document.getElementById('strength-fill');
    const label    = document.getElementById('strength-label');
    const matchMsg = document.getElementById('match-msg');
    const submitBtn = document.getElementById('submit-btn');

    function getStrength(pwd) {
      let score = 0;
      if (pwd.length >= 8)  score++;
      if (pwd.length >= 12) score++;
      if (/[A-Z]/.test(pwd)) score++;
      if (/[0-9]/.test(pwd)) score++;
      if (/[^A-Za-z0-9]/.test(pwd)) score++;
      return score;
    }

    const levels = [
      { pct: '0%',   color: 'transparent',          text: '',        textColor: 'var(--text-muted)' },
      { pct: '25%',  color: '#ff4b4b',               text: 'Weak',    textColor: '#ff7a7a' },
      { pct: '50%',  color: '#f97316',               text: 'Fair',    textColor: '#fb923c' },
      { pct: '75%',  color: '#e8c84a',               text: 'Good',    textColor: 'var(--accent)' },
      { pct: '88%',  color: '#4ade80',               text: 'Strong',  textColor: '#4ade80' },
      { pct: '100%', color: '#4ade80',               text: 'Strong',  textColor: '#4ade80' },
    ];

    newPwd.addEventListener('input', () => {
      const score = getStrength(newPwd.value);
      const lv = levels[score] || levels[0];
      fill.style.width = lv.pct;
      fill.style.background = lv.color;
      label.textContent = lv.text;
      label.style.color = lv.textColor;
      checkMatch();
    });

    // ─── Confirm password match check ────────────────────────
    function checkMatch() {
      if (!confirmPwd.value) {
        matchMsg.textContent = '';
        confirmPwd.classList.remove('input--error', 'input--success');
        submitBtn.disabled = true;
        return;
      }
      const match = newPwd.value === confirmPwd.value;
      confirmPwd.classList.toggle('input--error', !match);
      confirmPwd.classList.toggle('input--success', match);
      matchMsg.textContent = match ? '✓ Passwords match' : '✗ Passwords do not match';
      matchMsg.style.color = match ? '#4ade80' : '#ff7a7a';
      submitBtn.disabled = !match || newPwd.value.length < 8;
    }

    confirmPwd.addEventListener('input', checkMatch);

    // Disable submit on page load until valid
    submitBtn.disabled = true;
  </script>
