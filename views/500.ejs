<%- include('includes/Head') %>

  <%- include('includes/Navigation') %>

  <!-- ─── Error Page ───────────────────────────────────────────── -->
  <main class="error-page">

    <div class="auth-glow auth-glow--left"></div>
    <div class="auth-glow auth-glow--right"></div>

    <div class="error-container">

      <!-- ─── Left Panel: Error Code ───────────────────────── -->
      <div class="error-panel error-panel--code">
        <div class="error-panel-inner">

          <!-- Logo -->
          <a href="/" class="auth-logo">
            <div class="logo-mark">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 11l1.5-4.5A2 2 0 016.4 5h11.2a2 2 0 011.9 1.5L21 11M3 11v5a1 1 0 001 1h1a2 2 0 004 0h6a2 2 0 004 0h1a1 1 0 001-1v-5M3 11h18M7 17a1 1 0 110-2 1 1 0 010 2zm10 0a1 1 0 110-2 1 1 0 010 2z"/>
              </svg>
            </div>
            <span class="logo-text">Drive<span>Elite</span></span>
          </a>

          <!-- Big status code -->
          <div class="error-code-wrap">
            <span class="error-code"><%= statusCode %></span>
            <div class="error-code-glow"></div>
          </div>

          <!-- Decorative car art -->
          <div class="brand-car-art" aria-hidden="true">
            <svg viewBox="0 0 320 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 62 L52 34 L90 28 L160 24 L220 28 L262 34 L290 50 L300 62 L300 72 L20 72 Z"
                stroke="rgba(232,200,74,0.18)" stroke-width="1.5" fill="rgba(232,200,74,0.03)"/>
              <circle cx="75"  cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="245" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="75"  cy="72" r="4"  fill="rgba(232,200,74,0.2)"/>
              <circle cx="245" cy="72" r="4"  fill="rgba(232,200,74,0.2)"/>
            </svg>
          </div>

        </div>
      </div><!-- /.error-panel--code -->

      <!-- ─── Right Panel: Message + Actions ───────────────── -->
      <div class="error-panel error-panel--info">
        <div class="error-info-inner">

          <!-- Tag -->
          <span class="auth-tag">
            <% if (statusCode >= 500) { %>
              Server Error
            <% } else if (statusCode === 404) { %>
              Page Not Found
            <% } else if (statusCode === 403) { %>
              Access Denied
            <% } else if (statusCode === 401) { %>
              Unauthorised
            <% } else { %>
              Error
            <% } %>
          </span>

          <!-- Heading -->
          <h1 class="error-title">
            <% if (statusCode === 404) { %>
              Looks like this road<br/>doesn't exist.
            <% } else if (statusCode === 403) { %>
              You're not allowed<br/>down this road.
            <% } else if (statusCode === 401) { %>
              You need to sign in<br/>to continue.
            <% } else if (statusCode >= 500) { %>
              Something went<br/>wrong on our end.
            <% } else { %>
              An error<br/>occurred.
            <% } %>
          </h1>

          <!-- Error message from server -->
          <div class="error-message-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
            </svg>
            <span><%= message %></span>
          </div>

          <!-- Action buttons -->
          <div class="error-actions">

            <a href="/" class="auth-btn auth-btn--primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
              </svg>
              Go Home
            </a>

            <% if (statusCode === 401 || statusCode === 403) { %>
              <a href="/admin/signin" class="auth-btn auth-btn--ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
                </svg>
                Sign In
              </a>
            <% } else { %>
              <a href="javascript:history.back()" class="auth-btn auth-btn--ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
                </svg>
                Go Back
              </a>
            <% } %>

          </div><!-- /.error-actions -->

        </div>
      </div><!-- /.error-panel--info -->

    </div><!-- /.error-container -->
  </main>

  <%- include('includes/Footer') %>

  <style>
    /* ─── Error Page ─────────────────────────────────────────── */
    .error-page {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 100px 24px 60px;
      z-index: 1;
      overflow: hidden;
    }

    /* ─── Glow ───────────────────────────────────────────────── */
    .auth-glow {
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
      filter: blur(80px);
    }
    .auth-glow--left {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(232,200,74,0.07) 0%, transparent 70%);
      top: 10%; left: -100px;
    }
    .auth-glow--right {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(255,75,75,0.06) 0%, transparent 70%);
      bottom: 10%; right: -80px;
    }

    /* ─── Container ──────────────────────────────────────────── */
    .error-container {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 960px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.03);
      animation: errorIn 0.6s cubic-bezier(0.4,0,0.2,1) both;
    }

    @keyframes errorIn {
      from { opacity: 0; transform: translateY(32px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ─── Left Panel ─────────────────────────────────────────── */
    .error-panel--code {
      position: relative;
      background: linear-gradient(145deg, #0e0e18 0%, #111120 60%, #141428 100%);
      border-right: 1px solid var(--card-border);
      overflow: hidden;
    }

    /* Gold top line */
    .error-panel--code::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    /* Subtle background glow */
    .error-panel--code::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 50% at 30% 20%, rgba(232,200,74,0.06) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 80%, rgba(255,75,75,0.05) 0%, transparent 60%);
      pointer-events: none;
    }

    .error-panel-inner {
      position: relative;
      z-index: 1;
      padding: 48px 40px;
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    /* ─── Logo ───────────────────────────────────────────────── */
    .auth-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .logo-mark {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: var(--accent);
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .logo-mark svg {
      width: 20px; height: 20px;
      fill: none;
      stroke: var(--bg);
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .logo-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
      letter-spacing: 0.08em;
      color: var(--text-primary);
    }

    .logo-text span { color: var(--accent); }

    /* ─── Error Code ─────────────────────────────────────────── */
    .error-code-wrap {
      position: relative;
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .error-code {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 140px;
      line-height: 1;
      letter-spacing: 0.04em;
      color: transparent;
      -webkit-text-stroke: 2px rgba(232,200,74,0.4);
      text-stroke: 2px rgba(232,200,74,0.4);
      user-select: none;
      position: relative;
      z-index: 1;
    }

    .error-code-glow {
      position: absolute;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(232,200,74,0.12) 0%, transparent 70%);
      filter: blur(30px);
      pointer-events: none;
    }

    /* ─── Car Art ────────────────────────────────────────────── */
    .brand-car-art {
      opacity: 0.8;
    }
    .brand-car-art svg { width: 100%; }

    /* ─── Right Panel ────────────────────────────────────────── */
    .error-panel--info {
      background: var(--card-bg);
    }

    .error-info-inner {
      padding: 48px 40px;
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: 20px;
      justify-content: center;
    }

    /* ─── Tag ────────────────────────────────────────────────── */
    .auth-tag {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      background: var(--accent-dim);
      border: 1px solid rgba(232,200,74,0.25);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      width: fit-content;
    }

    /* ─── Title ──────────────────────────────────────────────── */
    .error-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 38px;
      letter-spacing: 0.04em;
      color: var(--text-primary);
      line-height: 1.15;
      margin-top: 4px;
    }

    /* ─── Message Box ────────────────────────────────────────── */
    .error-message-box {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 14px 16px;
      background: rgba(255,75,75,0.07);
      border: 1px solid rgba(255,75,75,0.2);
      border-radius: 10px;
      font-size: 13px;
      color: #ff9a9a;
      line-height: 1.6;
    }

    .error-message-box svg {
      width: 16px; height: 16px;
      flex-shrink: 0;
      margin-top: 2px;
      stroke: #ff7a7a;
    }

    /* ─── Actions ────────────────────────────────────────────── */
    .error-actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 8px;
    }

    .auth-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 14px 20px;
      border-radius: var(--radius-btn);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.04em;
      cursor: pointer;
      text-decoration: none;
      transition: all var(--transition);
      border: none;
    }

    .auth-btn svg { width: 16px; height: 16px; flex-shrink: 0; }

    .auth-btn--primary {
      background: var(--accent);
      color: var(--bg);
      text-transform: uppercase;
      position: relative;
      overflow: hidden;
    }

    .auth-btn--primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0);
      transition: background var(--transition);
    }

    .auth-btn--primary:hover::before { background: rgba(255,255,255,0.12); }
    .auth-btn--primary:active { transform: scale(0.98); }

    .auth-btn--ghost {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--card-border);
      color: var(--text-label);
      font-size: 13px;
    }

    .auth-btn--ghost:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.12);
      color: var(--text-primary);
    }

    .auth-btn--ghost svg { stroke: currentColor; }

    /* ─── Responsive ─────────────────────────────────────────── */
    @media (max-width: 768px) {
      .error-container {
        grid-template-columns: 1fr;
        max-width: 480px;
      }
      .error-panel--code { display: none; }
      .error-info-inner { padding: 40px 28px; }
    }

    @media (max-width: 480px) {
      .error-page { padding: 90px 16px 40px; }
      .error-info-inner { padding: 32px 20px; }
    }
  </style>

