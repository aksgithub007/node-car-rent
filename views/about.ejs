<style>
  /* ─── Shared Tokens (mirrors existing pages) ─────────────────── */
  :root {
    --accent: #e8c84a;
    --bg: #0a0a0f;
    --surface: #111118;
    --card-bg: #13131c;
    --card-border: rgba(255,255,255,0.07);
    --text-primary: #f0f0f8;
    --text-label: #b0b0c8;
    --text-muted: #6b6b80;
    --radius: 16px;
    --radius-btn: 10px;
    --transition: 0.2s ease;
  }

  /* ─── Glow helpers ───────────────────────────────────────────── */
  .about-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
    z-index: 0;
  }
  .about-glow--left {
    width: 560px; height: 560px;
    background: radial-gradient(circle, rgba(232,200,74,0.07) 0%, transparent 70%);
    top: -80px; left: -160px;
  }
  .about-glow--right {
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(100,80,200,0.06) 0%, transparent 70%);
    top: 40%; right: -100px;
  }

  /* ─── Hero ───────────────────────────────────────────────────── */
  .about-hero {
    position: relative;
    overflow: hidden;
    padding: 140px 24px 80px;
    text-align: center;
  }
  .about-hero-inner { position: relative; z-index: 2; max-width: 760px; margin: 0 auto; }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .about-hero-title {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 24px;
  }
  .about-hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .about-hero-sub {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-label);
    max-width: 560px;
    margin: 0 auto 48px;
  }

  .about-hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: 16px;
  }
  .astat { text-align: center; padding: 0 32px; }
  .astat-value {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.04em;
  }
  .astat-label {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }
  .astat-divider {
    width: 1px;
    height: 36px;
    background: var(--card-border);
    flex-shrink: 0;
  }

  .hero-car-art {
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: min(700px, 100%);
    z-index: 1;
    pointer-events: none;
    opacity: 0.7;
  }
  .hero-car-art svg { width: 100%; }

  /* ─── Shared Section Styles ──────────────────────────────────── */
  .about-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .section-tag {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--accent);
    text-transform: uppercase;
    background: rgba(232,200,74,0.08);
    border: 1px solid rgba(232,200,74,0.2);
    border-radius: 20px;
    padding: 5px 14px;
    margin-bottom: 20px;
  }

  .section-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .section-heading.centered { text-align: center; }

  .section-sub {
    font-size: 16px;
    color: var(--text-muted);
    margin-bottom: 52px;
  }
  .section-sub.centered { text-align: center; }

  .body-text {
    font-size: 15px;
    line-height: 1.8;
    color: var(--text-label);
    margin-bottom: 20px;
  }

  /* ─── Mission ────────────────────────────────────────────────── */
  .mission-section { border-top: 1px solid var(--card-border); }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    padding: 14px 28px;
    background: var(--accent);
    color: var(--bg);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-btn);
    transition: all var(--transition);
  }
  .about-cta:hover { opacity: 0.88; transform: translateY(-1px); }
  .about-cta svg { width: 15px; height: 15px; }

  .mission-image-wrap {
    position: relative;
    border-radius: var(--radius);
    overflow: visible;
  }

  .mission-image {
    width: 100%;
    border-radius: var(--radius);
    object-fit: cover;
    height: 380px;
    display: block;
    border: 1px solid var(--card-border);
  }

  .mission-image-badge {
    position: absolute;
    bottom: -20px;
    left: -20px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    backdrop-filter: blur(12px);
  }
  .badge-num {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }
  .badge-lbl {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 4px;
    white-space: nowrap;
  }

  /* ─── Values ─────────────────────────────────────────────────── */
  .values-section {
    border-top: 1px solid var(--card-border);
    text-align: center;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .value-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 32px 24px;
    text-align: left;
    transition: border-color var(--transition), transform var(--transition);
  }
  .value-card:hover {
    border-color: rgba(232,200,74,0.25);
    transform: translateY(-4px);
  }

  .value-icon {
    width: 44px; height: 44px;
    background: rgba(232,200,74,0.08);
    border: 1px solid rgba(232,200,74,0.18);
    border-radius: 12px;
    display: grid;
    place-items: center;
    margin-bottom: 20px;
  }
  .value-icon svg {
    width: 20px; height: 20px;
    stroke: var(--accent);
  }

  .value-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

