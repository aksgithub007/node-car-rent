<!-- ─── Hero ────────────────────────────────────────────────── -->
<section class="about-hero">
  <div class="about-glow about-glow--left"></div>
  <div class="about-glow about-glow--right"></div>

  <div class="about-hero-inner">
    <p class="hero-eyebrow">// Our Story</p>
    <h1 class="about-hero-title">Born from a<br/><em>Passion</em> for<br/>the Road.</h1>
    <p class="about-hero-sub">
      DriveElite started with a simple belief — renting a premium car should feel
      as good as driving one. No paperwork nightmares, no hidden costs, just you
      and an extraordinary machine.
    </p>
    <div class="about-hero-stats">
      <div class="astat">
        <span class="astat-value">2018</span>
        <span class="astat-label">Founded</span>
      </div>
      <div class="astat-divider"></div>
      <div class="astat">
        <span class="astat-value">48+</span>
        <span class="astat-label">Premium Vehicles</span>
      </div>
      <div class="astat-divider"></div>
      <div class="astat">
        <span class="astat-value">12K+</span>
        <span class="astat-label">Happy Drivers</span>
      </div>
      <div class="astat-divider"></div>
      <div class="astat">
        <span class="astat-value">12</span>
        <span class="astat-label">Cities</span>
      </div>
    </div>
  </div>

  <!-- Decorative large car SVG -->
  <div class="hero-car-art" aria-hidden="true">
    <svg viewBox="0 0 600 160" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 110 L90 60 L160 46 L300 38 L420 46 L510 64 L560 90 L570 110 L570 130 L30 130 Z"
