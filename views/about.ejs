<!-- ─── Timeline ─────────────────────────────────────────────── -->
<section class="about-section timeline-section">
  <div class="section-tag">Our Journey</div>
  <h2 class="section-heading centered">How We Got Here</h2>

  <div class="timeline">

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-year">2018</div>
      <div class="tl-content">
        <h4 class="tl-title">The Idea</h4>
        <p class="tl-desc">Rohan and Priya launched DriveElite out of a tiny Pune garage with 4 cars and a shared Google Sheet for bookings.</p>
      </div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-year">2019</div>
      <div class="tl-content">
        <h4 class="tl-title">First 500 Rentals</h4>
        <p class="tl-desc">Word-of-mouth drove us to our first 500 customers. We reinvested every rupee into expanding the fleet to 15 premium vehicles.</p>
      </div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-year">2021</div>
      <div class="tl-content">
        <h4 class="tl-title">Digital Platform Launch</h4>
        <p class="tl-desc">We replaced spreadsheets with a full booking platform. Instant confirmation, live availability, and zero phone calls needed.</p>
      </div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-year">2022</div>
      <div class="tl-content">
        <h4 class="tl-title">Expanded to 6 Cities</h4>
        <p class="tl-desc">Mumbai, Delhi, Bangalore, Chennai, Hyderabad, and Pune — DriveElite became a truly national brand.</p>
      </div>
    </div>

    <div class="tl-item">
      <div class="tl-dot tl-dot--active"></div>
      <div class="tl-year accent">2024</div>
      <div class="tl-content">
        <h4 class="tl-title">48+ Cars, 12 Cities & Growing</h4>
        <p class="tl-desc">Today we operate the finest curated rental fleet in India with a 4.9★ average rating across 12,000+ trips.</p>
      </div>
    </div>

  </div>
</section>

