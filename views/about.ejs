      <circle cx="460" cy="130" r="22" stroke="rgba(232,200,74,0.2)" stroke-width="1.5" fill="none"/>
      <circle cx="130" cy="130" r="7"  fill="rgba(232,200,74,0.15)"/>
      <circle cx="460" cy="130" r="7"  fill="rgba(232,200,74,0.15)"/>
      <line x1="30" y1="130" x2="570" y2="130" stroke="rgba(232,200,74,0.08)" stroke-width="1"/>
    </svg>
  </div>
</section>

<!-- ─── Mission ──────────────────────────────────────────────── -->
<section class="about-section mission-section">
  <div class="section-tag">Our Mission</div>
  <div class="mission-grid">
    <div class="mission-text">
      <h2 class="section-heading">Redefining what<br/>car rental looks like.</h2>
      <p class="body-text">
        The traditional rental experience is broken — long queues, confusing contracts,
        and fleet-of-the-month vehicles you'd never choose yourself. We set out to fix all of that.
      </p>
      <p class="body-text">
        DriveElite curates only the finest vehicles from top manufacturers, pairs them
        with a seamless digital booking flow, and backs every rental with round-the-clock
        concierge support. Whether you need a weekend escape in a sports car or a business
        trip in a luxury sedan, we have the right key for you.
      </p>
      <a href="/" class="about-cta">
        Browse Our Fleet
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
    <div class="mission-image-wrap">
      <img
        src="https://images.unsplash.com/photo-1503736334956-4c8f8e92946d?w=700&q=80"
        alt="Luxury car on an open road"
        class="mission-image"
        loading="lazy"
      />
      <div class="mission-image-badge">
        <span class="badge-num">6+</span>
        <span class="badge-lbl">Years of Excellence</span>
      </div>
    </div>
  </div>
</section>

