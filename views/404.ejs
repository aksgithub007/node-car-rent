<!-- ─── 404 Styles ─────────────────────────────────────────── -->
<style>
  /* ── Layout ── */
  .not-found {
    position: relative;
    z-index: 10;
    min-height: calc(100vh - 72px);
    margin-top: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 64px;
    overflow: hidden;
  }

  /* ── Ambient glow ── */
  .nf-glow {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(232,200,74,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Giant background 404 ── */
  .nf-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(180px, 28vw, 360px);
    letter-spacing: -0.02em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(232,200,74,0.07);
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
  }

  /* ── Content ── */
  .nf-content {
    position: relative;
    z-index: 2;
    max-width: 640px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }

  /* ── Eyebrow ── */
  .nf-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
  }

  /* ── Title ── */
  .nf-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(64px, 10vw, 96px);
    letter-spacing: 0.04em;
    line-height: 0.95;
    color: var(--text-primary);
  }

  .nf-title em {
    font-style: normal;
    color: var(--accent);
  }

  /* ── Subtitle ── */
  .nf-subtitle {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 480px;
  }

  /* ── Quick-links ── */
  .nf-link-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .nf-link-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
  }

  .nf-link-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition), transform var(--transition), box-shadow var(--transition);
  }

  .nf-link-card:hover {
    border-color: rgba(232,200,74,0.3);
    background: #16161f;
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.35), 0 0 0 1px rgba(232,200,74,0.08);
  }

  .nf-link-icon {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: var(--accent-dim);
    border: 1px solid rgba(232,200,74,0.15);
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: background var(--transition);
  }

  .nf-link-card:hover .nf-link-icon {
    background: rgba(232,200,74,0.18);
  }

  .nf-link-icon svg {
    width: 16px;
    height: 16px;
    stroke: var(--accent);
  }

  .nf-link-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .nf-link-text strong {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .nf-link-text small {
    font-size: 11px;
    color: var(--text-muted);
  }

  .nf-link-arrow {
    width: 14px;
    height: 14px;
    stroke: var(--text-muted);
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition), transform var(--transition);
  }

  .nf-link-card:hover .nf-link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Go back button ── */
  .nf-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    border-radius: var(--radius-btn);
    border: 1px solid var(--card-border);
    background: transparent;
    color: var(--text-muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all var(--transition);
  }

  .nf-back-btn svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    fill: none;
    transition: transform var(--transition);
  }

  .nf-back-btn:hover {
    color: var(--text-primary);
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
  }

  .nf-back-btn:hover svg {
    transform: translateX(-3px);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .not-found {
      padding: 60px 24px;
    }
  }

  @media (max-width: 560px) {
    .nf-link-grid {
      grid-template-columns: 1fr;
    }
    .nf-content {
      gap: 22px;
    }
  }
</style>

<%- include("includes/Footer") %>
