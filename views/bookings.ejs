<%- include('includes/Head') %>
<%- include('includes/Navigation') %>

<%
  /*
    Controller passes:
      bookings → array of booking subdocs
      car      → nested array [[car1, car2, ...]]  (controller does car.push(cars))
    Flatten once, then look up each car by _id per booking via findCar().
  */
  const carList = (car && car.length && Array.isArray(car[0])) ? car[0] : (car || []);
  function findCar(bookingCarId) {
    if (!bookingCarId) return null;
    return carList.find(c => c._id && c._id.toString() === bookingCarId.toString()) || null;
  }
%>

<main class="bookings-page">

  <!-- ── Page Hero ─────────────────────────────────────── -->
  <section class="bk-hero">
    <div class="bk-hero-inner">
      <div class="bk-hero-meta">
        <span class="bk-tag">My Garage</span>
        <div class="bk-hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-val"><%= bookings ? bookings?.length : 0 %></span>
            <span class="hero-stat-lbl">Total</span>
          </div>
          <div class="hero-stat-div"></div>
          <div class="hero-stat">
            <span class="hero-stat-val"><%= bookings ? bookings?.filter(b => b.status === 'confirmed').length : 0 %></span>
            <span class="hero-stat-lbl">Confirmed</span>
          </div>
          <div class="hero-stat-div"></div>
          <div class="hero-stat">
            <span class="hero-stat-val"><%= bookings ? bookings?.filter(b => b.status === 'paid').length : 0 %></span>
            <span class="hero-stat-lbl">Paid</span>
          </div>
          <div class="hero-stat-div"></div>
          <div class="hero-stat">
            <span class="hero-stat-val"><%= bookings ? bookings?.filter(b => b.status === 'cancelled').length : 0 %></span>
            <span class="hero-stat-lbl">Cancelled</span>
          </div>
        </div>
      </div>
      <h1 class="bk-hero-title">Your <span>Bookings</span></h1>
      <p class="bk-hero-sub">Track, manage and pay for all your DriveElite rentals in one place.</p>
    </div>

    <!-- Scrolling ticker -->
    <div class="bk-ticker" aria-hidden="true">
      <div class="ticker-track">
        <span>DRIVE ELITE</span><span class="ticker-dot">◆</span>
        <span>PREMIUM RENTALS</span><span class="ticker-dot">◆</span>
        <span>YOUR BOOKINGS</span><span class="ticker-dot">◆</span>
        <span>DRIVE ELITE</span><span class="ticker-dot">◆</span>
        <span>PREMIUM RENTALS</span><span class="ticker-dot">◆</span>
        <span>YOUR BOOKINGS</span><span class="ticker-dot">◆</span>
        <span>DRIVE ELITE</span><span class="ticker-dot">◆</span>
        <span>PREMIUM RENTALS</span><span class="ticker-dot">◆</span>
        <span>YOUR BOOKINGS</span><span class="ticker-dot">◆</span>
        <span>DRIVE ELITE</span><span class="ticker-dot">◆</span>
        <span>PREMIUM RENTALS</span><span class="ticker-dot">◆</span>
        <span>YOUR BOOKINGS</span><span class="ticker-dot">◆</span>
      </div>
    </div>
  </section>

  <!-- ── Filter Bar ──────────────────────────────────── -->
  <section class="bk-filters">
    <div class="bk-filters-inner">
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="all">
          All <span class="filter-count"><%= bookings ? bookings?.length : 0 %></span>
        </button>
        <button class="filter-tab" data-filter="confirmed">
          Confirmed <span class="filter-count"><%= bookings ? bookings?.filter(b => b.status === 'confirmed').length : 0 %></span>
        </button>
        <button class="filter-tab" data-filter="paid">
          Paid <span class="filter-count"><%= bookings ? bookings?.filter(b => b.status === 'paid').length : 0 %></span>
        </button>
        <button class="filter-tab" data-filter="cancelled">
          Cancelled <span class="filter-count"><%= bookings ? bookings?.filter(b => b.status === 'cancelled').length : 0 %></span>
        </button>
        <button class="filter-tab" data-filter="completed">
          Completed <span class="filter-count"><%= bookings ? bookings?.filter(b => b.status === 'completed').length : 0 %></span>
        </button>
      </div>
      <div class="filter-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
        </svg>
        <input type="text" id="searchInput" placeholder="Search by booking ID…" />
      </div>
    </div>
  </section>

  <!-- ── Bookings Grid ───────────────────────────────── -->
  <section class="bk-grid-section">
    <div class="bk-grid" id="bookingsGrid">

      <% if (!bookings || bookings?.length === 0) { %>

        <!-- Empty state -->
        <div class="bk-empty">
          <div class="bk-empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
            </svg>
          </div>
          <h3>No bookings yet</h3>
          <p>Start your DriveElite journey by booking a premium vehicle.</p>
          <a href="/cars" class="bk-cta-btn">Browse Cars</a>
        </div>

      <% } else { %>

        <% bookings.forEach((booking, i) => { %>

        <%
          /* Safe date parsing */
          const pickup  = new Date(booking.pickupDate)
          const dropoff = new Date(booking.dropoffDate)
          const days    = booking.totalDays || Math.ceil((dropoff - pickup) / (1000*60*60*24))
          const bookingIdShort = booking._id ? booking._id.toString().slice(-6).toUpperCase() : '------'
          /* Look up the car that matches this booking's carId */
          const thisCar = findCar(booking.carId)
          const carName = thisCar ? (thisCar.name || '').toLowerCase() : ''
        %>

        <article
          class="bk-card"
          data-status="<%= booking.status %>"
          data-id="<%= bookingIdShort.toLowerCase() %>"
          data-name="<%= carName %>"
          style="animation-delay: <%= i * 70 %>ms"
        >

          <!-- Status ribbon -->
          <div class="bk-card-ribbon bk-card-ribbon--<%= booking.status %>">
            <span class="ribbon-status">
              <span class="ribbon-dot"></span>
              <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
            </span>
            <span class="ribbon-id">#<%= bookingIdShort %></span>
          </div>

          <!-- Car visual -->
          <div class="bk-card-visual">
            <% if (thisCar && thisCar.imageUrl) { %>
              <img src="<%= thisCar.imageUrl %>" alt="<%= thisCar.name %>" class="bk-car-img" loading="lazy" />
            <% } else { %>
              <div class="bk-car-placeholder">
                <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
                </svg>
              </div>
            <% } %>

            <% if (thisCar && thisCar.category) { %>
              <span class="bk-category-pill"><%= thisCar.category %></span>
            <% } %>

            <!-- Hover overlay -->
            <div class="bk-card-hover-overlay">
              <span class="overlay-id">Booking #<%= bookingIdShort %></span>
            </div>
          </div>

          <!-- Car identity -->
          <div class="bk-card-identity">
            <% if (thisCar) { %>
              <div class="bk-car-brand"><%= thisCar.brand || 'Unknown Brand' %></div>
              <h3 class="bk-car-name"><%= thisCar.name || 'Car' %></h3>
            <% } else { %>
              <div class="bk-car-brand">Car ID</div>
              <h3 class="bk-car-name"><%= booking.carId %></h3>
            <% } %>
          </div>

          <!-- Specs row (only if car data available) -->
          <% if (thisCar) { %>
          <div class="bk-specs-row">
            <% if (thisCar.seatCapacity) { %>
            <div class="bk-spec">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
              </svg>
              <span><%= thisCar.seatCapacity %> seats</span>
            </div>
            <% } %>
            <% if (thisCar.transmission) { %>
            <div class="bk-spec">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/>
              </svg>
              <span><%= thisCar.transmission %></span>
            </div>
            <% } %>
            <% if (thisCar.fuelType) { %>
            <div class="bk-spec">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>
              </svg>
              <span><%= thisCar.fuelType %></span>
            </div>
            <% } %>
          </div>
          <% } %>

          <!-- Date range -->
          <div class="bk-dates">
            <div class="bk-date-block">
              <span class="bk-date-lbl">Pick Up</span>
              <span class="bk-date-val">
                <%= pickup.toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
              </span>
            </div>
            <div class="bk-date-arrow">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/>
              </svg>
            </div>
            <div class="bk-date-block bk-date-block--right">
              <span class="bk-date-lbl">Drop Off</span>
              <span class="bk-date-val">
                <%= dropoff.toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
              </span>
            </div>
          </div>

          <!-- Duration + rate row -->
          <div class="bk-duration-row">
            <span class="bk-duration-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <%= days %> day<%= days !== 1 ? 's' : '' %>
            </span>
            <% if (thisCar && thisCar.rentalPrice) { %>
              <span class="bk-rate">₹<%= thisCar.rentalPrice %>/day</span>
            <% } %>
          </div>

          <!-- Total price -->
          <div class="bk-price-row">
            <span class="bk-price-lbl">Total Amount</span>
            <span class="bk-price-val">
              ₹<%= (booking.totalPrice || 0).toLocaleString('en-IN') %>
            </span>
          </div>

          <!-- Action buttons -->
          <div class="bk-actions">

            <% if (booking.status === 'confirmed') { %>

              <!-- Pay Now -->
              <a href="/bookings/<%= booking._id %>/pay" style="text-decoration:none; flex:1;">
                <button type="button" class="bk-btn bk-btn--pay" style="width:100%">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
                  </svg>
                  Pay Now
                </button>
              </a>

              <!-- Cancel -->
              <form action="/bookings/<%= booking._id %>/cancel" method="POST" onsubmit="return confirmCancel(this)">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="bk-btn bk-btn--cancel">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  Cancel
                </button>
              </form>

            <% } else if (booking.status === 'paid') { %>

              <!-- Paid success badge -->
              <span class="bk-paid-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                Payment Complete
              </span>

              <!-- Rebook same car -->
              <% if (thisCar) { %>
                <a href="/book/<%= thisCar._id %>" class="bk-btn bk-btn--rebook">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
                  </svg>
                  Rebook
                </a>
              <% } %>

            <% } else if (booking.status === 'completed') { %>

              <!-- Completed badge -->
              <span class="bk-completed-badge">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                Completed
              </span>

              <!-- Book Again -->
              <% if (thisCar) { %>
                <a href="/cars/<%= thisCar._id %>" class="bk-btn bk-btn--rebook">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
                  </svg>
                  Book Again
                </a>
              <% } %>

            <% } else { %>

              <!-- Cancelled -->
              <span class="bk-cancelled-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                Booking Cancelled
              </span>

            <% } %>

          </div>

        </article>
        <% }) %>

      <% } %>

    </div>
  </section>

</main>
<%- include('includes/Toast') %>
<%- include('includes/Footer') %>

<!-- ── Cancel Confirmation Modal ──────────────────────── -->
<div class="bk-modal-overlay" id="cancelModal">
  <div class="bk-modal">
    <div class="bk-modal-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ff7a7a" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
    </div>
    <h3 class="bk-modal-title">Cancel Booking?</h3>
    <p class="bk-modal-text">This action cannot be undone. Your booking will be permanently cancelled.</p>
    <div class="bk-modal-actions">
      <button class="bk-modal-btn bk-modal-btn--ghost" onclick="closeModal()">Keep Booking</button>
      <button class="bk-modal-btn bk-modal-btn--danger" id="confirmCancelBtn">Yes, Cancel</button>
    </div>
  </div>
</div>

<style>
  /* ══════════════════════════════════════════════════════
     BOOKINGS PAGE — FULLY SELF-CONTAINED STYLES
  ══════════════════════════════════════════════════════ */
  .bookings-page * { box-sizing: border-box; }

  .bookings-page {
    background: #0a0a0f;
    min-height: 100vh;
    padding-top: 72px;
    font-family: 'DM Sans', sans-serif;
    color: #f0f0f5;
  }

  /* ── Hero ──────────────────────────────────────────── */
  .bk-hero {
    position: relative;
    padding: 56px 64px 0;
    overflow: hidden;
  }
  .bk-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 10% 50%, rgba(232,200,74,.07) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 90% 20%, rgba(100,80,200,.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .bk-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 40px;
  }

  .bk-hero-meta {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .bk-tag {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 100px;
    background: rgba(232,200,74,.12);
    border: 1px solid rgba(232,200,74,.25);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #e8c84a;
  }

  .bk-hero-stats { display: flex; align-items: center; gap: 20px; }
  .hero-stat-div { width: 1px; height: 28px; background: #1e1e2e; }
  .hero-stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: #f0f0f5;
    line-height: 1;
    display: block;
  }
  .hero-stat-lbl { font-size: 10px; color: #6b6b80; text-transform: uppercase; letter-spacing: .08em; }

  .bk-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 8vw, 96px);
    letter-spacing: .04em;
    color: #f0f0f5;
    line-height: .95;
    margin: 0;
  }
  .bk-hero-title span { color: #e8c84a; }

  .bk-hero-sub { font-size: 15px; color: #6b6b80; margin-top: 14px; max-width: 480px; }

  /* Ticker */
  .bk-ticker {
    border-top: 1px solid #1e1e2e;
    border-bottom: 1px solid #1e1e2e;
    overflow: hidden;
    padding: 10px 0;
    margin-top: 40px;
    background: rgba(255,255,255,.01);
  }
  .ticker-track {
    display: flex;
    gap: 32px;
    white-space: nowrap;
    animation: tickerScroll 22s linear infinite;
    width: max-content;
  }
  .ticker-track span { font-family: 'Bebas Neue', sans-serif; font-size: 13px; letter-spacing: .14em; color: #2a2a3a; }
  .ticker-dot { color: #e8c84a !important; font-size: 8px !important; }
  @keyframes tickerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Filter bar ────────────────────────────────────── */
  .bk-filters {
    position: sticky;
    top: 72px;
    z-index: 50;
    background: rgba(10,10,15,.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid #1e1e2e;
    padding: 12px 64px;
  }
  .bk-filters-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .filter-tabs { display: flex; gap: 4px; }
  .filter-tab {
    padding: 7px 16px;
    border-radius: 8px;
    border: none;
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #6b6b80;
    cursor: pointer;
    transition: all .2s ease;
  }
  .filter-tab:hover { color: #f0f0f5; background: rgba(255,255,255,.04); }
  .filter-tab.active {
    background: rgba(232,200,74,.12);
    border: 1px solid rgba(232,200,74,.2);
    color: #e8c84a;
    font-weight: 600;
  }
  .filter-search {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,.03);
    border: 1px solid #1e1e2e;
    border-radius: 8px;
    padding: 8px 14px;
    transition: border-color .2s;
  }
  .filter-search:focus-within { border-color: rgba(232,200,74,.4); }
  .filter-search svg { stroke: #6b6b80; flex-shrink: 0; }
  .filter-search input {
    background: none;
    border: none;
    outline: none;
    color: #f0f0f5;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    width: 180px;
  }
  .filter-search input::placeholder { color: #4a4a60; }

  /* ── Grid ──────────────────────────────────────────── */
