<%- include('includes/Head') %>

  <%- include('includes/Navigation') %>

  <!-- ─── Auth Page Wrapper ────────────────────────────────────── -->
  <main class="auth-page">

    <!-- Background decorative glow -->
    <div class="auth-glow auth-glow--left"></div>
    <div class="auth-glow auth-glow--right"></div>

    <div class="auth-container">

      <!-- ─── Left Panel: Branding ─────────────────────────────── -->
      <div class="auth-panel auth-panel--brand">
        <div class="brand-panel-inner">

          <a href="/" class="auth-logo">
            <div class="logo-mark">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 11l1.5-4.5A2 2 0 016.4 5h11.2a2 2 0 011.9 1.5L21 11M3 11v5a1 1 0 001 1h1a2 2 0 004 0h6a2 2 0 004 0h1a1 1 0 001-1v-5M3 11h18M7 17a1 1 0 110-2 1 1 0 010 2zm10 0a1 1 0 110-2 1 1 0 010 2z"/>
              </svg>
            </div>
            <span class="logo-text">Drive<span>Elite</span></span>
          </a>

          <div class="brand-copy">
            <h2 class="brand-heading">Welcome back,<br/>drive in style.</h2>
            <p class="brand-sub">Access your bookings, manage rentals, and discover premium vehicles curated just for you.</p>
          </div>

          <ul class="brand-features">
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Instant booking confirmation</span>
            </li>
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>No hidden fees, ever</span>
            </li>
            <li>
              <span class="feat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
              <span>Cancel or modify anytime</span>
            </li>
          </ul>

          <!-- Decorative car silhouette line -->
          <div class="brand-car-art" aria-hidden="true">
            <svg viewBox="0 0 320 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 62 L52 34 L90 28 L160 24 L220 28 L262 34 L290 50 L300 62 L300 72 L20 72 Z"
                stroke="rgba(232,200,74,0.18)" stroke-width="1.5" fill="rgba(232,200,74,0.03)"/>
              <circle cx="75" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="245" cy="72" r="12" stroke="rgba(232,200,74,0.25)" stroke-width="1.5" fill="none"/>
              <circle cx="75" cy="72" r="4" fill="rgba(232,200,74,0.2)"/>
              <circle cx="245" cy="72" r="4" fill="rgba(232,200,74,0.2)"/>
            </svg>
          </div>

        </div>
      </div><!-- /.auth-panel--brand -->

      <!-- ─── Right Panel: Form ─────────────────────────────────── -->
      <div class="auth-panel auth-panel--form">
        <div class="form-panel-inner">

          <div class="auth-form-header">
            <span class="auth-tag">Member Access</span>
            <h1 class="auth-title">Sign In</h1>
            <p class="auth-subtitle">Enter your credentials to continue</p>
          </div>

          <% if (locals.error) { %>
            <div class="auth-alert auth-alert--error">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
              </svg>
              <span><%= error %></span>
            </div>
          <% } %>

          <form action="/admin/signin" method="POST" class="auth-form" novalidate>
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <!-- Email -->
            <div class="field-group">
              <label class="field-label" for="email">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
                Email Address
              </label>
              <div class="field-wrap">
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="field-input"
                  placeholder="you@example.com"
                  autocomplete="email"
                  required
                  autofocus
                />
              </div>
            </div>

            <!-- Password -->
            <div class="field-group">
              <label class="field-label" for="password">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                </svg>
                Password
              </label>
              <div class="field-wrap field-wrap--password">
                <input
                  type="password"
                  id="password"
                  name="password"
                  class="field-input"
                  placeholder="Enter your password"
                  autocomplete="current-password"
                  required
                />
                <button type="button" class="pwd-toggle" aria-label="Toggle password visibility" onclick="togglePassword('password', this)">
                  <svg class="eye-show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <svg class="eye-hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Forgot password -->
            <div class="field-meta">
              <a href="/admin/reset-password" class="auth-link auth-link--sm">Forgot password?</a>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-btn auth-btn--primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
              </svg>
              Sign In
            </button>

          </form>
           <!-- ─── OAuth Divider ─────────────────────────────────── -->
            <!-- ─── OAuth Divider ─────────────────────────────────── -->
          <div class="auth-divider"><span>or continue with</span></div>

          <!-- ─── OAuth Buttons ─────────────────────────────────── -->
          <div class="oauth-grid">

            <a href="/auth/google" class="oauth-btn">
              <span class="oauth-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:block;width:20px;height:20px;flex-shrink:0">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </span>
              <span>Google</span>
            </a>

            <a href="/auth/facebook" class="oauth-btn">
              <span class="oauth-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:block;width:20px;height:20px;flex-shrink:0">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/>
                </svg>
              </span>
              <span>Facebook</span>
            </a>

            <a href="/auth/linkedin" class="oauth-btn">
              <span class="oauth-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:block;width:20px;height:20px;flex-shrink:0">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" fill="#0A66C2"/>
                </svg>
              </span>
              <span>LinkedIn</span>
            </a>

          </div>


          <div class="auth-divider"><span>New to DriveElite?</span></div>

          <a href="/admin/signup" class="auth-btn auth-btn--ghost">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>
            </svg>
            Create an Account
          </a>

        </div>
      </div><!-- /.auth-panel--form -->

    </div><!-- /.auth-container -->
  </main>
<%- include('includes/Toast') %>
  <%- include('includes/Footer') %>


  <script>
    function togglePassword(inputId, btn) {
      const input = document.getElementById(inputId);
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      btn.querySelector('.eye-show').style.display = isText ? '' : 'none';
      btn.querySelector('.eye-hide').style.display = isText ? 'none' : '';
    }
    // Auto-focus first visible field on page load
    document.addEventListener('DOMContentLoaded', function() {
      const first = document.querySelector('.field-input:not([type="hidden"]), .field-select');
      if (first) first.focus();
    });
  </script>
